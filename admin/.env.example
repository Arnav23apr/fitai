# Supabase — service role key REQUIRED for admin reads (RLS bypass).
# Get from: Supabase Studio → Project Settings → API → service_role secret.
# NEVER commit the real value. NEVER expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<paste service_role key here>

# Admin login (single user)
ADMIN_EMAIL=admin@fitai.app
ADMIN_PASSWORD=FitAI-Admin-2026!

# Cookie signing secret. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-32-byte-random-hex-string

# Optional: RevenueCat REST API for /revenue page.
# Get from: RevenueCat dashboard → Project settings → API keys → "Secret API key" (v2).
REVENUECAT_SECRET_KEY=
REVENUECAT_PROJECT_ID=
